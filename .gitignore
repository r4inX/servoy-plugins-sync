# ------------------------------------------------------------------
# Servoy Gold Plugin Sync – .gitignore
# ------------------------------------------------------------------

# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
*.whl

# Virtual environments
.venv/
venv/
env/
.env/

# ── Personal config files (NEVER commit – contains local paths) ─
# Each developer keeps their own copy outside this repo.
.servoy-plugin-sync.json
*/.servoy-plugin-sync.json

# ── Runtime artefacts generated by the tools ────────────────────
# These live inside the Servoy installation, not the repo.
.gold_sync_state.json
gold_plugins_sync.log
gold_plugins_sync.log.*

# ── OS / editor noise ───────────────────────────────────────────
# Windows
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~

# JetBrains IDEs
.idea/

# VS Code (keep .vscode/extensions.json if present, ignore the rest)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ── Temporary / test artefacts ───────────────────────────────────
*.tmp
*.bak
*.swp
tmp/
temp/
