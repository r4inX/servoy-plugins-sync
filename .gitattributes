# Set default behaviour: normalise line endings on check-in
* text=auto

# Shell scripts must always use LF (they run on Unix/macOS)
*.sh text eol=lf

# Windows batch scripts must always use CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Python and Markdown: normalise to LF
*.py  text eol=lf
*.md  text eol=lf
*.json text eol=lf

# Binary files – no line-ending conversion
*.jar binary
*.zip binary
*.png binary
*.jpg binary
*.gif binary
